# Banco de dados PostgreSQL
# Formato: postgresql://USUARIO:SENHA@HOST:PORTA/NOME_DO_BANCO
DATABASE_URL=postgresql://admin:admin123@localhost:5432/storeline

# Segredo para assinar os tokens JWT — use um valor longo e aleatório em produção
# Gerar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=troque-por-um-valor-seguro-em-producao
